[user]
	name = ThomasK

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[pull]
	rebase = true

[rerere]
	enabled = true

[commit]
	gpgsign = true

[gpg]
	format = ssh

[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers

[user]
	signingkey = ~/.ssh/id_ed25519.pub

[core]
	excludesFile = ~/.gitignore_global

[diff]
	algorithm = histogram

[include]
	path = ~/.gitconfig.local
